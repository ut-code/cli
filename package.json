{
	"name": "utcode-cli",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "bun run src/main.tsx",
		"format": "bunx --bun @biomejs/biome check --write .",
		"build": "bun build src/main.tsx --outdir dist --target node --packages external && echo '#!/usr/bin/env node' | cat - dist/main.js > dist/main.js.tmp && mv dist/main.js.tmp dist/main.js"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/bun": "latest",
		"@types/react": "^19.2.14"
	},
	"overrides": {
		"ink": "^6.8.0",
		"react": "^19.2.4"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"ink": "^6.8.0",
		"ink-big-text": "^2.0.0",
		"react": "^19.2.4"
	},
	"bin": {
		"utcode": "./dist/main.js"
	}
}
